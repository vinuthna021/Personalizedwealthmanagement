# ========================================================
# Production Environment Variable Template for Render Backend
# ========================================================

# 1. Database Connection (Neon PostgreSQL)
# Format: postgresql://[user]:[password]@[neon-host].neon.tech/[dbname]?sslmode=require
DATABASE_URL=postgresql://wealth_user:your_secure_neon_password@ep-cool-name.us-east-2.aws.neon.tech/wealth_db?sslmode=require

# 2. Redis Caching & Queue Connection (Upstash Redis)
# Format: rediss://default:[password]@[upstash-host].upstash.io:[port]
# Note the "rediss://" prefix for SSL/TLS encryption.
REDIS_URL=rediss://default:your_upstash_password@cool-redis-instance.upstash.io:6379

# 3. Session Cookie Hardening
# Enforce HTTPS-only secure cookie transmissions. Set to true in production.
SECURE_COOKIES=true

# 4. JWT Cryptographic Signing keys
# Hexadecimal signing secrets (generate using: openssl rand -hex 32)
JWT_SECRET_KEY=generate_hex_32_characters_for_access_token_signing
JWT_REFRESH_SECRET_KEY=generate_hex_32_characters_for_refresh_token_signing

# 5. Token Lifetimes (Access = 15m, Refresh = 7d)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# 6. CORS Allowed Origins (JSON array format)
# Include your Vercel deployment URL (and custom domain if applicable)
BACKEND_CORS_ORIGINS=["https://personalized-wealth-management.vercel.app", "https://yourcustomdomain.com"]

# 7. Fallback Market API Key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_production_api_key
